# Copy to .env and fill in values. Do not commit .env.

# Google Search Console verification (from search.google.com/search-console)
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics GA4 Measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# Formspree form ID (from formspree.io - the part after /f/)
PUBLIC_FORMSPREE_ENDPOINT=
