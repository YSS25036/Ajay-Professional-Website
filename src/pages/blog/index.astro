---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function getExcerpt(body: string, maxLength = 140): string {
	const plain = body
		.replace(/^---[\s\S]*?---/, '')
		.replace(/#{1,6}\s/g, '')
		.replace(/\*\*([^*]+)\*\*/g, '$1')
		.replace(/\*([^*]+)\*/g, '$1')
		.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
		.replace(/[#*_~`]/g, '')
		.replace(/\n+/g, ' ')
		.trim();
	return plain.length > maxLength ? plain.slice(0, maxLength).trim() + '…' : plain;
}
---

<BaseLayout title="Blog" description="Insights on technology leadership, M&A integration, DevOps, and Agile from Ajay K Madan.">
	<Header />
	<main class="main">
		<section class="blog-hero">
			<h1 class="blog-title">Insights & Articles</h1>
			<p class="blog-subtitle">
				Thoughts on AI-led software development, technology leadership, post-merger integration, DevOps, Agile, and building high-performing teams. Explore and find what resonates.
			</p>
		</section>

		{posts.length > 0 ? (
			<div class="post-tiles">
				{posts.map((post) => {
					const coverImg = post.data.coverImage || post.data.thumbnail;
					const imgSrc = coverImg ? `/images/blog/${coverImg}` : null;
					const excerpt = post.data.description || getExcerpt(post.body ?? '');
					return (
						<a href={`/blog/${post.slug}/`} class="post-tile">
							<div class={`tile-image-wrap ${imgSrc ? 'has-image' : ''}`}>
								{imgSrc ? (
									<img src={imgSrc} alt={post.data.title} class="tile-image" width="400" height="220" />
								) : (
									<div class="tile-placeholder">
										<span class="placeholder-icon" aria-hidden="true">📄</span>
									</div>
								)}
								<span class="tile-date">
									{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
								</span>
							</div>
							<div class="tile-content">
								<h2 class="tile-title">{post.data.title}</h2>
								<p class="tile-excerpt">{excerpt}</p>
								<span class="tile-cta">Read article →</span>
							</div>
						</a>
					);
				})}
			</div>
		) : (
			<div class="empty-state">
				<p>No posts yet. Add content via Decap CMS or create Markdown files in <code>src/content/blog/</code>.</p>
			</div>
		)}
	</main>
	<Footer />
</BaseLayout>

<style>
	.main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 8rem 1.5rem 4rem;
	}

	.blog-hero {
		text-align: center;
		margin-bottom: 3rem;
		padding: 0 1rem;
	}
	.blog-title {
		font-size: 2.5rem;
		font-weight: 700;
		color: #1a1a1a;
		margin: 0 0 0.75rem;
		letter-spacing: -0.02em;
	}
	.blog-subtitle {
		font-size: 1.15rem;
		line-height: 1.7;
		color: #555;
		max-width: 560px;
		margin: 0 auto;
	}

	.post-tiles {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2rem;
	}
	.post-tile {
		display: flex;
		flex-direction: column;
		background: #fff;
		border-radius: 12px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		border: 1px solid #e8e8e8;
		transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.2s ease;
	}
	.post-tile:hover {
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
		transform: translateY(-4px);
		border-color: #e67e22;
	}

	.tile-image-wrap {
		position: relative;
		aspect-ratio: 16 / 9;
		background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
		overflow: hidden;
	}
	.tile-image-wrap.has-image {
		background: #f0f0f0;
	}
	.tile-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}
	.post-tile:hover .tile-image {
		transform: scale(1.03);
	}
	.tile-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #fef9f5 0%, #f5ebe0 50%, #f0e6dc 100%);
	}
	.placeholder-icon {
		font-size: 3rem;
		opacity: 0.6;
	}
	.tile-date {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		background: rgba(0, 0, 0, 0.6);
		color: #fff;
		font-size: 0.8rem;
		font-weight: 500;
		padding: 0.35rem 0.65rem;
		border-radius: 6px;
		backdrop-filter: blur(4px);
	}
	.tile-image-wrap:not(.has-image) .tile-date {
		background: rgba(230, 126, 34, 0.9);
	}

	.tile-content {
		padding: 1.5rem 1.5rem 1.75rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}
	.tile-title {
		font-size: 1.25rem;
		font-weight: 600;
		color: #1a1a1a;
		margin: 0 0 0.6rem;
		line-height: 1.35;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post-tile:hover .tile-title {
		color: #e67e22;
	}
	.tile-excerpt {
		font-size: 0.95rem;
		line-height: 1.6;
		color: #555;
		margin: 0 0 1rem;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.tile-cta {
		font-size: 0.95rem;
		font-weight: 600;
		color: #e67e22;
		transition: transform 0.2s ease;
	}
	.post-tile:hover .tile-cta {
		transform: translateX(4px);
	}

	.empty-state {
		text-align: center;
		padding: 3rem 2rem;
		background: #f8f9fa;
		border-radius: 12px;
		border: 1px dashed #ddd;
	}
	.empty-state p {
		margin: 0;
		color: #666;
	}
	.empty-state code {
		background: #e8e8e8;
		padding: 0.2rem 0.5rem;
		border-radius: 4px;
		font-size: 0.9em;
	}

	@media (max-width: 768px) {
		.blog-title {
			font-size: 2rem;
		}
		.post-tiles {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}
</style>
