---
interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const { title, description = "Ajay K Madan - AI-SDLC transformation consultant & Fractional CTO. Helping medium and large enterprises adopt AI across the software development lifecycle: fast, measured, and safe. 25 yrs building enterprise products.", ogImage } = Astro.props;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const gscVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const site = Astro.site?.href ?? 'https://ajaykmadan.in';
const siteBase = site.endsWith('/') ? site : site + '/';
const canonicalUrl = new URL(Astro.url.pathname, siteBase).href;
const defaultOgImage = new URL('/images/Ajay-Profile-Pic-04.jpg', siteBase).href;
const imageUrl = ogImage ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage.replace(/^\//, ''), siteBase).href) : defaultOgImage;
const fullTitle = `${title} - Ajay K Madan`;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/images/cropped-Website-Logo-v2-copy.png" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		{gscVerification && <meta name="google-site-verification" content={gscVerification} />}
		<meta name="generator" content={Astro.generator} />
		<title>{fullTitle}</title>

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:site_name" content="Ajay K Madan" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />

		<!-- JSON-LD: Person + ProfessionalService (AI & search discoverability) -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Person",
					"@id": `${site}#person`,
					"name": "Ajay K Madan",
					"url": site,
					"jobTitle": "AI-SDLC Transformation Consultant, Fractional CTO",
					"description": "Consultant helping medium and large enterprises adopt AI across the software development lifecycle: AI-SDLC maturity assessment, migration factories, spec-driven development, measurement and governance. Also: engineering leadership, M&A technology integration, offshore development. 25 years building enterprise products.",
					"knowsAbout": ["AI SDLC", "AI-assisted software development", "spec-driven development", "legacy migration with AI", "engineering metrics and DORA", "AI governance in regulated industries", "fractional CTO leadership"],
					"image": defaultOgImage,
					"sameAs": ["https://www.linkedin.com/in/ajaykmadan/"]
				},
				{
					"@type": "ProfessionalService",
					"@id": `${site}#service`,
					"name": "Ajay K Madan - Technology Leadership",
					"url": site,
					"description": "AI-SDLC transformation and Fractional CTO consulting for medium and large enterprises: AI maturity assessment, rollout strategy with safeguards, migration factories, spec-driven development, measurement and governance. Plus engineering leadership, post-merger integration, offshore development.",
					"provider": { "@id": `${site}#person` },
					"serviceType": ["AI SDLC Transformation", "AI Adoption Consulting", "Fractional CTO", "Engineering Leadership", "Technology Consultant", "M&A Technology Integration"],
					"areaServed": { "@type": "Place", "name": "Global" }
				}
			]
		})} />
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}
	</head>
	<body>
		<slot />
	</body>
</html>
